# -----------------------------------------------------------------------------
# Gobber — environment template (portable, host-agnostic)
# Copy to `.env` locally, or set these in your host's dashboard.
# -----------------------------------------------------------------------------

# Supabase (or any Postgres+PostgREST+GoTrue compatible backend)
# Browser-visible (safe to ship)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...     # anon / publishable key
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT

# Server-side mirrors (used by TanStack server functions during SSR)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...         # secret, server-only

# Google Maps JavaScript API (Maps JS + Places enabled)
# Restrict by HTTP referrer to your deployed domain(s).
GOOGLE_MAPS_BROWSER_KEY=AIza...
VITE_GOOGLE_MAPS_API_KEY=AIza...                # same value, used by the client bundle

# Optional: AI features (swap Lovable AI Gateway for your own provider)
# OPENAI_API_KEY=sk-...
# GOOGLE_GENAI_API_KEY=...
